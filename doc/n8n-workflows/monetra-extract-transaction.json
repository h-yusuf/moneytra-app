    },
    "Save Raw to Sheets": {
      "main": [[{"node": "Read Latest from Sheets", "type": "main", "index": 0}]]
    },
    "Read Latest from Sheets": {
      "main": [[{"node": "Transform to App Format", "type": "main", "index": 0}]]
    },
    "Transform to App Format": {
      "main": [[{"node": "Save to Supabase", "type": "main", "index": 0}]]
    },
    "Save to Supabase": {
      "main": [[{"node": "Update Sheets Status", "type": "main", "index": 0}]]
    },
    "Update Sheets Status": {
      "main": [[{"node": "Build Response Payload", "type": "main", "index": 0}]]
    },
    "Build Response Payload": {
      "main": [[{"node": "Respond to App", "type": "main", "index": 0}]]
    }
  },
  "pinData": {},
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "instanceId": "monetra-money-saving"
  },
