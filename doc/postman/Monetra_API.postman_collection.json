    {
      "name": "Upload File (OCR + AI Extract)",
      "item": [
        {
          "name": "Upload Image - Struk/KTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "description": "Header auth wajib diisi (lihat credential di n8n)"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Upload file gambar (JPG/PNG) — struk belanja, bukti transfer, atau KTP"
                },
                {
                  "key": "type",
                  "value": "expense",
                  "type": "text",
                  "description": "Tipe transaksi: expense | wedding_savings"
                },
                {
                  "key": "user_id",
                  "value": "test-user-123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/webhook/uploadDoc",
              "host": ["{{base_url}}"],
              "path": ["webhook", "uploadDoc"]
            },
            "description": "Upload file gambar (JPG/PNG). n8n akan OCR via Tesseract → masking data sensitif (NIK/Nama) → AI Agent DeepSeek ekstrak data → response JSON.\n\n**Flow:** Webhook File upload → Check file type → Image to Text (Tesseract OCR) → Pisah Data Sensitive → AI Agent → Transform data → Response"
          },
          "response": []
        },
