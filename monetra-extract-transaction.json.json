                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{$json.data.type}}",
                    "rightValue": "money_saving",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              }
            }
          ]
        },
        "options": {}
