{
  "expo": {
    "name": "Monetra",
    "slug": "monetra-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./public/image/light-logo-app.png",
    "scheme": "monetraapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera to take photos of receipts for transaction tracking.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload receipt images.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#c8f542",
        "foregroundImage": "./public/image/light-logo-app.png",
        "backgroundImage": "./public/image/light-logo-app.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./public/image/light-logo-app.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./public/image/light-logo-app.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./public/image/dark-logo-app.png",
            "backgroundColor": "#0a0a0a"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
